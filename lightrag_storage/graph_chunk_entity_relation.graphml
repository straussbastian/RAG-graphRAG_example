  <data key="d0">Aktualisierung</data>
  <data key="d1">method</data>
  <data key="d2">A process for updating information, particularly where changes to one instance automatically propagate to linked instances</data>
  <data key="d3">doc-fb57212021fb1e5e7a76ae882be19321-chunk-039</data>
  <data key="d4">LizardDocu.md</data>
  <data key="d5">1781356265</data>
  <data key="d6"></data>
</node>
<node id="Anwendungsfall">
  <data key="d0">Anwendungsfall</data>
  <data key="d1">concept</data>
  <data key="d2">Scenarios or use cases illustrating how documents (individual or shared) are applied to specific or generalized equipment types</data>
  <data key="d3">doc-fb57212021fb1e5e7a76ae882be19321-chunk-039</data>
  <data key="d4">LizardDocu.md</data>
  <data key="d5">1781356265</data>
