  <data key="d4">LizardDocu.md</data>
  <data key="d5">1781356265</data>
  <data key="d6"></data>
</node>
<node id="Importanweisungen">
  <data key="d0">Importanweisungen</data>
  <data key="d1">data</data>
  <data key="d2">Instructions provided in a multi-line text field to guide AI in understanding fields, such as explaining how equipment numbers are structured.&lt;SEP&gt;Instructions field for guiding the AI during the import process of files.</data>
  <data key="d3">doc-fb57212021fb1e5e7a76ae882be19321-chunk-060&lt;SEP&gt;doc-fb57212021fb1e5e7a76ae882be19321-chunk-051</data>
  <data key="d4">LizardDocu.md</data>
  <data key="d5">1781356265</data>
  <data key="d6"></data>
</node>
